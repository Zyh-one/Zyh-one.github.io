body
  line-height: 1.78

.main-inner
  --content-desktop: 860px
  --content-desktop-large: 920px

.site-brand-container
  padding: 28px 20px

.site-title
  letter-spacing: 0
  font-weight: 700

.site-subtitle
  margin-top: 8px
  color: #5f6f7f
  line-height: 1.5

.site-nav
  border-top: 1px solid #edf0f3

.menu .menu-item a
  border-radius: 6px
  line-height: 1.7

.home-hero
  margin: 14px 12px 18px
  padding: 26px 28px
  border-radius: 8px
  background: #fff
  box-shadow: 0 10px 32px rgba(16, 24, 40, .06)
  display: grid
  grid-template-columns: minmax(0, 1fr) 220px
  gap: 24px
  align-items: center

.home-hero-eyebrow
  margin: 0 0 8px
  color: #6b7280
  font-size: 13px
  font-weight: 600

.home-hero-title
  margin: 0
  color: #1f2937
  font-size: 28px
  font-weight: 700
  line-height: 1.35

.home-hero-desc
  margin: 10px 0 14px
  color: #4b5563
  font-size: 16px
  line-height: 1.75

.home-hero-tags
  display: flex
  flex-wrap: wrap
  gap: 8px

.home-hero-tags span
  border: 1px solid #dbe4ea
  border-radius: 999px
  padding: 4px 9px
  color: #0f766e
  font-size: 12px
  line-height: 1.4
  background: #f7fbfa

.home-hero-aside
  display: flex
  flex-direction: column
  gap: 8px

.home-hero-aside-title
  margin: 0 0 2px
  color: #6b7280
  font-size: 13px
  font-weight: 700

.home-hero-aside a,
.home-hero-aside span
  display: block
  border-radius: 6px
  padding: 8px 10px
  background: #f3f4f6
  color: #374151
  font-size: 13px
  font-weight: 600
  line-height: 1.35
  text-align: center

.home-hero-aside a:hover
  background: #0f766e
  color: #fff

.post-block
  border-radius: 8px
  box-shadow: 0 10px 32px rgba(16, 24, 40, .06)

.post-title
  letter-spacing: 0
  line-height: 1.35

.post-body
  color: #1f2a37
  font-size: 16px
  line-height: 1.86

.post-body h2
  margin-top: 2.2em
  padding-bottom: .35em
  border-bottom: 1px solid #e5e7eb

.post-body h3
  margin-top: 1.8em

.post-body p,
.post-body ul,
.post-body ol
  margin: 1em 0

.post-button .btn
  border-radius: 999px
  padding: 7px 18px

.sidebar-inner
  border-radius: 8px
  box-shadow: 0 10px 32px rgba(16, 24, 40, .05)

code
  border-radius: 4px

@media (max-width: 767px)
  .site-brand-container
    padding: 22px 16px

  .home-hero
    margin: 12px 0 16px
    padding: 22px 18px
    grid-template-columns: 1fr

  .home-hero-title
    font-size: 23px

  .home-hero-desc
    font-size: 15px

  .post-body
    font-size: 15px
